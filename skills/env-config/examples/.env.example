# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name and environment
APP_NAME=MyApp
APP_ENV=development  # Options: development, staging, production
DEBUG=true

# Logging configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text
LOG_FILE=logs/app.log

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Primary database connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/myapp_dev

# Database pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis cache (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================================================
# API KEYS AND EXTERNAL SERVICES
# ============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_ORG_ID=org-your-org-id

# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_APP_URL=https://yourapp.com

# Other AI Services
HUGGINGFACE_TOKEN=
COHERE_API_KEY=

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Email settings
FROM_EMAIL=noreply@yourapp.com
ADMIN_EMAIL=admin@yourapp.com

# ============================================================================
# SECURITY AND AUTHENTICATION
# ============================================================================

# Secret keys (MUST be random in production!)
SECRET_KEY=change-this-to-random-secret-key-in-production
JWT_SECRET=change-this-jwt-secret-key
ENCRYPTION_KEY=base64-encoded-32-byte-encryption-key

# Session configuration
SESSION_LIFETIME=3600  # seconds
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# CLOUD SERVICES
# ============================================================================

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_PROJECT_ID=your-project-id

# Azure
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_CONTAINER_NAME=your-container

# ============================================================================
# MONITORING AND ANALYTICS
# ============================================================================

# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application monitoring
NEW_RELIC_LICENSE_KEY=
DATADOG_API_KEY=

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
ENABLE_ANALYTICS=false
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_2FA=false

# Maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We'll be back soon!

# ============================================================================
# RATE LIMITING AND QUOTAS
# ============================================================================

# API rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Usage quotas
MAX_REQUESTS_PER_DAY=10000
MAX_STORAGE_MB=1000

# ============================================================================
# PAYMENT AND BILLING
# ============================================================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox  # Options: sandbox, live

# ============================================================================
# DEVELOPMENT AND TESTING
# ============================================================================

# Testing settings
TEST_DATABASE_URL=postgresql://localhost:5432/myapp_test
RUN_MIGRATIONS_ON_STARTUP=false

# Debug tools
ENABLE_DEBUG_TOOLBAR=true
ENABLE_PROFILING=false
MOCK_EXTERNAL_APIS=false

# Hot reload
AUTO_RELOAD=true
WATCH_FILES=true

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================
# When APP_ENV=production, these should be set differently:
#
# DEBUG=false
# LOG_LEVEL=WARNING
# SESSION_COOKIE_SECURE=true
# CORS_ORIGINS=https://yourapp.com
# RATE_LIMIT_ENABLED=true
# ENABLE_DEBUG_TOOLBAR=false
# MAINTENANCE_MODE=false
#
# And use strong, random values for:
# SECRET_KEY, JWT_SECRET, ENCRYPTION_KEY
# ============================================================================

# ============================================================================
# CUSTOM APPLICATION VARIABLES
# ============================================================================

# Add your application-specific variables below
# Examples:
# MAX_UPLOAD_SIZE_MB=10
# DEFAULT_LANGUAGE=en
# TIMEZONE=UTC
